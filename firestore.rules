rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUser() {
      return userDoc(request.auth.uid).data;
    }

    function hasRole(role) {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUser().role == role;
    }

    function isAdmin() {
      return hasRole('admin')
        && request.auth.token.email in [
          'admin@stratmore.edu',
          'admin@strathmore.edu'
        ];
    }

    function isSeller() {
      return hasRole('seller');
    }

    function sellerHasActiveSubscription() {
      return isSeller()
        && currentUser().subscription_status == 'active';
    }

    function validCategory(category) {
      return category in [
        'household_items',
        'books',
        'electronics',
        'clothes',
        'shoes',
        'jewellery'
      ];
    }

    function validStatus(status) {
      return status in ['pending', 'active', 'sold', 'deleted'];
    }

    function validProductBase(data) {
      return data.title is string
        && data.seller_id is string
        && validCategory(data.category)
        && validStatus(data.status);
    }

    function createsOwnPendingProduct() {
      return sellerHasActiveSubscription()
        && request.resource.data.seller_id == request.auth.uid
        && request.resource.data.status == 'pending'
        && validProductBase(request.resource.data);
    }

    function updatesOwnProductWithoutApproval() {
      return sellerHasActiveSubscription()
        && resource.data.seller_id == request.auth.uid
        && request.resource.data.seller_id == resource.data.seller_id
        && request.resource.data.status != 'active'
        && !(resource.data.status == 'pending'
          && request.resource.data.status == 'active')
        && validProductBase(request.resource.data);
    }

    function buyerMarksPurchasedProductSold() {
      return signedIn()
        && resource.data.status == 'active'
        && request.resource.data.status == 'sold'
        && request.resource.data.seller_id == resource.data.seller_id
        && request.resource.data.sold_to == request.auth.uid
        && validProductBase(request.resource.data);
    }

    function isBuyerOfProduct(productId) {
      return signedIn()
        && exists(/databases/$(database)/documents/products/$(productId))
        && get(/databases/$(database)/documents/products/$(productId)).data.sold_to == request.auth.uid;
    }

    function validReview(data) {
      return data.product_id is string
        && data.product_title is string
        && data.seller_id is string
        && data.buyer_id is string
        && data.rating in [1, 2, 3];
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['buyer', 'seller']
        && request.resource.data.subscription_status in ['active', 'inactive'];
      allow update: if isAdmin()
        || (signedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.subscription_status == resource.data.subscription_status);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if signedIn()
        && (resource.data.status == 'active'
          || resource.data.sold_to == request.auth.uid
          || isAdmin()
          || resource.data.seller_id == request.auth.uid);

      allow create: if createsOwnPendingProduct();

      allow update: if isAdmin()
        || updatesOwnProductWithoutApproval()
        || buyerMarksPurchasedProductSold();

      allow delete: if isAdmin()
        || (sellerHasActiveSubscription()
          && resource.data.seller_id == request.auth.uid);
    }

    match /reviews/{reviewId} {
      allow read: if isAdmin()
        || resource.data.buyer_id == request.auth.uid
        || resource.data.seller_id == request.auth.uid;

      allow create, update: if signedIn()
        && validReview(request.resource.data)
        && request.resource.data.buyer_id == request.auth.uid
        && isBuyerOfProduct(request.resource.data.product_id)
        && request.resource.data.seller_id ==
          get(/databases/$(database)/documents/products/$(request.resource.data.product_id)).data.seller_id;

      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || resource.data.reporter_id == request.auth.uid
        || resource.data.seller_id == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.reporter_id == request.auth.uid
        && request.resource.data.product_id is string
        && request.resource.data.reason is string
        && request.resource.data.status == 'pending';

      allow update, delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin()
        || resource.data.user_id == request.auth.uid
        || resource.data.seller_id == request.auth.uid;

      allow create: if signedIn()
        && request.resource.data.user_id == request.auth.uid;

      allow update: if isAdmin()
        || resource.data.user_id == request.auth.uid;

      allow delete: if isAdmin();
    }
  }
}
